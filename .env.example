# ============================================
# DEVARSENAL - Environment Variables Example
# ============================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# -- DATABASE --
DATABASE_URL="postgresql://username:password@localhost:5432/devarsenal"
DIRECT_URL="postgresql://username:password@localhost:5432/devarsenal"

# -- NEXT AUTH --
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# -- STRIPE --
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_STUDIO_PRICE_ID="price_..."

# -- EMAIL (Resend) --
RESEND_API_KEY="re_..."
EMAIL_FROM="DevArsenal <noreply@devarsenal.com>"

# -- ANALYTICS --
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# -- STORAGE (optional) --
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# -- APP URLS --
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DASHBOARD_URL="http://localhost:3001"

# -- FEATURE FLAGS --
ENABLE_AI_FEATURES="true"
ENABLE_TEAMS="true"
ENABLE_AUDIT_LOGS="true"
